# Application
APP_NAME=RectitudeAI
APP_VERSION=2.0.0
DEBUG=True
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=ayushtandonvartikamanish
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# LLM Configuration
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://your-remote-ollama-ip:11434
# Recommended for standalone: gemma:2b or llama3.2:3b
DEFAULT_MODEL=gemma:2b

# Optional Cloud LLMs (Require API Keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile


# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Redis (for production)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
